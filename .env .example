# Server
PORT=3000
NODE_ENV=development
JWT_SECRET=super_secret_jwt_key_change_this
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:3000

# Turso DBs (Create 3 separate databases in Turso dashboard)
TURSO_ACCOUNTS_URL=libsql://fims-accounts-your-org.turso.io
TURSO_ACCOUNTS_TOKEN=your_accounts_token
TURSO_INVENTORY_URL=libsql://fims-inventory-your-org.turso.io
TURSO_INVENTORY_TOKEN=your_inventory_token
TURSO_AUDIT_URL=libsql://fims-audit-your-org.turso.io
TURSO_AUDIT_TOKEN=your_audit_token

# Email (Gmail App Password recommended)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
MAIL_FROM="FIMS System <your-email@gmail.com>"
ADMIN_EMAIL=admin@company.com

# Telegram
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_ID=987654321

# Backups
BACKUP_DIR=./backups
BACKUP_CRON=0 2 * * *
TZ=UTC